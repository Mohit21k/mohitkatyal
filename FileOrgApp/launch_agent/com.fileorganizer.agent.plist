<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fileorganizer.agent</string>
    <key>ProgramArguments</key>
    <array>
        <!-- This will be replaced during installation script with absolute paths -->
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>TARGET_DIR/main.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>TARGET_DIR</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>TARGET_DIR/logs/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>TARGET_DIR/logs/stderr.log</string>
</dict>
</plist>
